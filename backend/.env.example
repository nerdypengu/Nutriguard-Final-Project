# ==========================================
# VERCEL DEPLOYMENT - CRITICAL VARIABLES
# ==========================================
# ⚠️ THESE ARE REQUIRED FOR VERCEL TO WORK ⚠️
# 
# Add these to Vercel Project Settings → Environment Variables:
# 1. Go to https://vercel.com/dashboard
# 2. Select your project
# 3. Go to Settings → Environment Variables
# 4. Add ALL REQUIRED variables below
#
# Without these, the function will fail with FUNCTION_INVOCATION_FAILED

# ========== REQUIRED ==========
# Supabase Configuration (ABSOLUTELY REQUIRED)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key

# JWT Secret (REQUIRED for authentication to work)
JWT_SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars

# Bot API (Recommended)
BOT_API_KEY=your-secure-bot-api-key-change-in-production

# ==========================================
# Redis Configuration
# ==========================================
# For local development: redis://localhost:6379/0
# For Docker: redis://redis:6379/0
# For cloud (e.g., Redis Cloud): redis://:password@host:port/db
#
# ⚠️ IMPORTANT FOR VERCEL/PRODUCTION:
# If Redis is unavailable (leave blank or don't set), the app will:
# - Use in-memory fallback cache (limited to current function invocation)
# - Use in-memory rate limiting (basic but functional)
# This is safe for production but less performant than Redis.

REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds (default: 1 hour = 3600)
REDIS_CACHE_TTL=3600

# Rate limit TTL in seconds (default: 1 minute = 60)
REDIS_RATE_LIMIT_TTL=60

# Make Redis optional (default: true - Redis is optional)
REDIS_OPTIONAL=true

# ==========================================
# Bot Service Account Configuration
# ==========================================
# API key for bot/n8n service account to get JWT tokens
# Change this to a secure value in production!

BOT_API_KEY=your-secure-bot-api-key-change-in-production
BOT_SERVICE_ID=nutriguard-bot

# ==========================================
# Keycloak Configuration
# ==========================================
# Set these to your Keycloak server instance details
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=nutriguard
KEYCLOAK_CLIENT_ID=nutriguard-backend
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret

# ==========================================
# VERCEL DEPLOYMENT
# ==========================================
# When deploying to Vercel:
# 1. Go to your Vercel Project Settings
# 2. Navigate to "Environment Variables"
# 3. Add all the configuration above, especially:
#    - SUPABASE_URL (required)
#    - SUPABASE_KEY (required)
#    - JWT_SECRET_KEY (required)
#    - BOT_API_KEY (recommended)
#
# Note: Redis and Keycloak are optional. If not provided,
# some features will be limited but the app will still run.
